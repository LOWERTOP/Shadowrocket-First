#!name=🅲🅻🅴🅰🅽🅴🆁
#!desc=自用测试模块，编辑参数以使用
#!arguments=歌词翻译:false, 翻译账户:申请并填入百度翻译AppID, 翻译密钥:申请并填入百度翻译密钥, 精简底栏:true, 接力功能:true
#!arguments-desc=歌词翻译功能说明\n\n· 歌词翻译功能有效性暂不确定\n\n· 需申请百度翻译API的ID和密钥并填入，推荐高级版\n\n· 申请时建议使用桌面设备，移动设备可能访问失败\n\n· 成功启用后，歌词界面左下角即可看到翻译按钮\n\n - 注册百度翻译个人开发者，高级版需要实名认证: \n\n    http://api.fanyi.baidu.com/register\n\n - 开通(通用文本翻译)API服务: \n\n    https://fanyi-api.baidu.com/choose\n\n - 成功后即可看到自己的AppID和密钥(不要泄露): \n\n    http://api.fanyi.baidu.com/manage/developer
# 整理作者：LOWERTOP
# 仓库地址：https://github.com/LOWERTOP/Shadowrocket-First

[Rule]
DOMAIN,ad.12306.cn,DIRECT,extended-matching
IP-CIDR,203.107.1.1/24,REJECT,no-resolve,pre-matching
URL-REGEX,"^http?:\/\/(discardrp|startup)\.umetrip\.com\/gateway\/api\/umetrip\/native",REJECT,extended-matching

# QUIC BLOCK
AND,((DOMAIN-SUFFIX,spotify.com),(PROTOCOL,QUIC)),REJECT-NO-DROP
AND,((DOMAIN-SUFFIX,ddgksf2013.top),(PROTOCOL,QUIC)),REJECT-NO-DROP

# 红果短剧部分去广告规则
DOMAIN-WILDCARD,*-misc-lq.fqnovel.com,REJECT-DROP
DOMAIN-WILDCARD,*-reading-ad.qznovelvod.com,REJECT-DROP
DOMAIN-WILDCARD,*-ad-sign.byteimg.com,REJECT-DROP
DOMAIN-WILDCARD,*-iosreadingvideo.qznovelvod.com,REJECT-DROP

# 包子漫画所需特定规则
DOMAIN-SUFFIX,baozimhcn.com,DIRECT
DOMAIN-SUFFIX,baozimh.com,DIRECT
DOMAIN-SUFFIX,baozicdn.com,DIRECT
DOMAIN-SUFFIX,dzmanga.com,DIRECT
DOMAIN-SUFFIX,twmanga.com,DIRECT
DOMAIN-SUFFIX,baozimhapp.com,REJECT

# DeepSeek 规则
# 以下为该软件的疑似上传地址
DOMAIN-SUFFIX,apmplus.volces.com,REJECT
DOMAIN-SUFFIX,gator.volces.com,REJECT
DOMAIN-SUFFIX,guh50jw4-ios.mobile-messenger.intercom.com,REJECT
# 以下为该软件代理规则集
# RULE-SET,https://lowertop.github.io/Shadowrocket-First/DeepSeek.list,PROXY

# 美图
DOMAIN-SUFFIX,corp.meitu.com,REJECT
DOMAIN-SUFFIX,gg.meitu.com,REJECT
DOMAIN-SUFFIX,message.meitu.com,REJECT
DOMAIN-SUFFIX,tuiguang.meitu.com,REJECT
DOMAIN-SUFFIX,xiuxiu.android.dl.meitu.com,REJECT
DOMAIN-SUFFIX,adui.tg.meitu.com,REJECT
DOMAIN-SUFFIX,rabbit.tg.meitu.com,REJECT
DOMAIN-SUFFIX,meitubeauty.meitudata.com,REJECT
DOMAIN-SUFFIX,xiuxiu.mobile.meitudata.com,REJECT
DOMAIN-SUFFIX,dc.meitustat.com,REJECT
DOMAIN-SUFFIX,mdc.meitustat.com,REJECT
DOMAIN-SUFFIX,rabbit.meitustat.com,REJECT

[URL Rewrite]
# 包子漫画横幅APP广告
^https?:\/\/static-tw\.baozimh\.com\/bzmhapp-data\/pics\/install_app_bar_baozimhappx\.jpg$ - REJECT

# 小蚁
^https?://api.xiaoyi.com\/v5\/app\/mobile\/ads - REJECT
^https?://api.xiaoyi.com\/v5\/app\/config\?userid=.* - REJECT

# 001ProMax
^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/artistview\/v1\/artist\/(.*)&platform=iphone https://spclient.wg.spotify.com/artistview/v1/artist/$1&platform=ipad header

# 美图
^https?:\/\/mea\.meitudata\.com\/kaiping - REJECT

# 大师兄
^http:\/\/[a-zA-Z0-9_-]+(\.[a-zA-Z0-9_-]+){1,4}(:\d+)?\/.*?\/v\d\/(version|notice\?|top_notice\?|advert\?position=[^2]+) - REJECT-200

# 移动弹窗
^https?:\/\/h\.app\.coc\.10086\.cn\/biz-orange\/DH\/popupWindow\/getDetail - REJECT-200

[Body Rewrite]
http-response-jq ^https:\/\/pan\.baidu\.com\/feed\/kingkongdistrict\? '.data.data |= map(select(.type != "novel" and .type != "shortplay" and .type != "print" and .type != "job_hunt"))'

# 大师兄
http-response-jq ^http:\/\/[a-zA-Z0-9_-]+(\.[a-zA-Z0-9_-]+){1,4}(:\d+)?\/api\/v\d\/config\/getConfigList\.do '.data |= map(select(.keyName | test("config\\.(ad|search|recommend)") | not))'
http-response-jq ^http:\/\/app\.dsx\.ac\/ndsx\.php\/v\d\/logs 'del(.data.banners) | if .data.is_top then .data = [] else . end'

[Map Local]
# 001ProMax
