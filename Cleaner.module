[Body Rewrite]
{{{百度网盘}}}http-response-jq ^https:\/\/pan\.baidu\.com\/feed\/kingkongdistrict\? '.data.data |= map(select(.type != "novel" and .type != "shortplay" and .type != "print" and .type != "job_hunt"))'

# 大师兄
{{{大师兄影视}}}http-response-jq ^http:\/\/[a-zA-Z0-9_-]+(\.[a-zA-Z0-9_-]+){1,4}(:\d+)?\/api\/v\d\/config\/getConfigList\.do '.data |= map(select(.keyName | test("config\\.(ad|search|recommend)") | not))'
{{{大师兄影视}}}http-response-jq ^http:\/\/app\.dsx\.ac\/ndsx\.php\/v\d\/logs 'del(.data.banners) | if .data.is_top then .data = [] else . end'

# PDD @XiangwanGuan
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? '.result.bottom_tabs? |= map(select(.link | IN("index.html", "chat_list.html", "personal.html"))) | .result.buffer_bottom_tabs? |= map(select(.link | IN("index.html", "chat_list.html", "personal.html"))) | .result.all_top_opts |= map(del(.selected_image, .image, .height, .width))'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? 'delpaths([["result","dy_module","irregular_banner_dy"],["result","icon_set"],["result","search_bar_hot_query"],["result","dy_module","irregular_banner_dy"]])'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/aristotle\/order_list_v\d+\? '.orders |= map(.order_buttons |= map(del(.order_growth_tip)))'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/caterham\/v\d+\/query\/order_detail_group\? 'delpaths([["data","goods_list"]])'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/oak\/integration\/render\? 'delpaths([["bottom_section_list"],["ui","bottom_section"],["ui","live_section","float_info"]])'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/api\/philo\/personal\/hub\? 'delpaths([["monthly_card_entrance"],["personal_center_style_v2_vo"],["icon_set","icons"],["icon_set","top_personal_icons"],["personal_banner"]])'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/order\/ 'delpaths([["marketing_banner_vo"],["shipping","banner_above_recommend"]])'
{{{拼多多}}}http-response-jq ^https?:\/\/api\.pinduoduo\.com\/search\? 'delpaths([["expansion"]])'

